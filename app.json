{
  "expo": {
    "name": "My Church",
    "slug": "my-church-app",
    "version": "5.0.0",
    "versionCode": 500,
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mychurch",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3498db"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "minimumOsVersion": "13.0",
      "bundleIdentifier": "com.henockaduma.mychurch",
      "infoPlist": {
        "NSCameraUsageDescription": "My Church a besoin d'accéder à votre caméra pour prendre des photos de profil des membres et le logo de l'église.",
        "NSPhotoLibraryUsageDescription": "My Church a besoin d'accéder à vos photos pour sélectionner des images de profil et le logo de l'église.",
        "NSMicrophoneUsageDescription": "My Church a besoin d'accéder au microphone pour certaines fonctionnalités."
      }
    },
    "android": {
      "minSdkVersion": 28,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "package": "com.henockaduma.mychurch",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-updates",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "My Church a besoin d'accéder à votre caméra pour prendre des photos de profil."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "My Church a besoin d'accéder à vos photos pour sélectionner des images."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "My Church a besoin d'accéder à votre bibliothèque pour sauvegarder des images.",
          "savePhotosPermission": "Autoriser My Church à sauvegarder des photos.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b211699b-c795-4122-8da0-cb2e1853a74a"
      }
    }
  }
}
